# Whanos Environment Configuration
# Copy this file to .env and fill in your actual values

# ===================================
# Azure Configuration
# ===================================
AZURE_SUBSCRIPTION_ID=your-subscription-id-here
RESOURCE_GROUP=WHANOS
LOCATION=francecentral

# Azure VM Details
VM_NAME=whanos-all
VM_PUBLIC_IP=<YOUR_VM_PUBLIC_IP>
SSH_USER=azureuser
SSH_KEY_PATH=~/.ssh/id_rsa

# ===================================
# Jenkins Configuration
# ===================================
JENKINS_URL=http://localhost:8080
JENKINS_ADMIN_USER=admin
JENKINS_ADMIN_PASSWORD=change-me-in-production

# ===================================
# Docker Registry Configuration
# ===================================
REGISTRY_HOST=localhost:5000
REGISTRY_URL=http://localhost:5000

# For Azure deployment:
# REGISTRY_HOST=<YOUR_VM_PUBLIC_IP>:5000
# REGISTRY_URL=http://<YOUR_VM_PUBLIC_IP>:5000

# ===================================
# Kubernetes Configuration
# ===================================
KUBECONFIG=/opt/whanos/kubeconfig

# ===================================
# Ansible Configuration
# ===================================
ANSIBLE_CONTROL_PLANE_IP=<YOUR_CONTROL_PLANE_IP>
ANSIBLE_WORKER_IP=<YOUR_WORKER_IP>
